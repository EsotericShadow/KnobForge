<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="KnobForge.App.Views.ProjectLauncherWindow"
    x:CompileBindings="False"
    Width="1020"
    Height="680"
    MinWidth="860"
    MinHeight="560"
    Title="Monozukuri Projects"
    Background="{StaticResource Surface0Brush}">
    <Window.Resources>
        <x:Double x:Key="LauncherHeroTitleSize">22</x:Double>
        <x:Double x:Key="LauncherHeroBadgeSize">10</x:Double>
        <x:Double x:Key="LauncherCardTitleSize">17</x:Double>
        <x:Double x:Key="LauncherCardMetaSize">12</x:Double>
        <x:Double x:Key="LauncherCardPathSize">11</x:Double>
        <x:Double x:Key="LauncherEmptyTitleSize">20</x:Double>
        <x:Double x:Key="LauncherEmptyBodySize">13</x:Double>

        <ControlTheme x:Key="ProjectListBoxItemTheme" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FocusAdorner">
                <FocusAdornerTemplate>
                    <Border/>
                </FocusAdornerTemplate>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="SelectionShell"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="12"
                            Padding="2">
                        <ContentPresenter x:Name="PART_ContentPresenter"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          Padding="{TemplateBinding Padding}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.launcher-hero-title">
            <Setter Property="FontSize" Value="{StaticResource LauncherHeroTitleSize}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="TextBlock.launcher-hero-tagline">
            <Setter Property="FontSize" Value="{StaticResource FontHint}"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
        </Style>

        <Style Selector="TextBlock.launcher-version-badge">
            <Setter Property="FontSize" Value="{StaticResource LauncherHeroBadgeSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.launcher-card-title">
            <Setter Property="FontSize" Value="{StaticResource LauncherCardTitleSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="TextBlock.launcher-card-meta">
            <Setter Property="FontSize" Value="{StaticResource LauncherCardMetaSize}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <Style Selector="TextBlock.launcher-card-path">
            <Setter Property="FontSize" Value="{StaticResource LauncherCardPathSize}"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
            <Setter Property="Opacity" Value="0.85"/>
        </Style>

        <Style Selector="TextBlock.launcher-empty-title">
            <Setter Property="FontSize" Value="{StaticResource LauncherEmptyTitleSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.launcher-empty-body">
            <Setter Property="FontSize" Value="{StaticResource LauncherEmptyBodySize}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="MaxWidth" Value="400"/>
        </Style>

        <Style Selector="Button#NewProjectButton">
            <Setter Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style Selector="Button#NewProjectButton:pointerover">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style Selector="Button#EmptyStateNewProjectButton">
            <Setter Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style Selector="Button#EmptyStateNewProjectButton:pointerover">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="4,8"/>
            <Style.Resources>
                <SolidColorBrush x:Key="ListBoxItemBackgroundSelected" Color="Transparent"/>
                <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedDisabled" Color="Transparent"/>
                <SolidColorBrush x:Key="ListBoxItemBackgroundPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="ListBoxItemBackgroundPressed" Color="Transparent"/>
                <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedPressed" Color="Transparent"/>
                <SolidColorBrush x:Key="SystemAccentColor" Color="Transparent"/>
                <SolidColorBrush x:Key="ListBoxItemSelectionIndicatorFill" Color="Transparent"/>
                <SolidColorBrush x:Key="ListBoxItemSelectionIndicatorPointerOverFill" Color="Transparent"/>
                <SolidColorBrush x:Key="ListBoxItemSelectionIndicatorDisabledFill" Color="Transparent"/>
            </Style.Resources>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FocusAdorner">
                <FocusAdornerTemplate>
                    <Border/>
                </FocusAdornerTemplate>
            </Setter>
        </Style>

        <!-- Kill the Fluent theme SelectionIndicator rectangle (source of the green system accent) -->
        <Style Selector="ListBox#ProjectListBox ListBoxItem /template/ Rectangle#SelectionIndicator">
            <Setter Property="IsVisible" Value="False"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected /template/ Border#Root">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:pointerover">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected:pointerover">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected:focus /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected:focus /template/ Border#Root">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected /template/ Border#SelectionShell">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected:pointerover /template/ Border#SelectionShell">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected:focus /template/ Border#SelectionShell">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:pointerover Border#ProjectCardBorder">
            <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected Border#ProjectCardBorder">
            <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="ListBox#ProjectListBox ListBoxItem:selected:focus Border#ProjectCardBorder">
            <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="Button#OpenSelectedProjectButton:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>

        <Style Selector="Button#BrowseProjectButton">
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style Selector="Button#OpenSelectedProjectButton">
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0"
                Background="{StaticResource Surface1Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,20">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Grid.Column="0" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Border Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource AccentSubtleBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1">
                            <Viewbox Width="22" Height="22" Margin="9">
                                <Canvas Width="16" Height="16">
                                    <Ellipse Width="14"
                                             Height="14"
                                             Canvas.Left="1"
                                             Canvas.Top="1"
                                             Stroke="{StaticResource TextPrimaryBrush}"
                                             StrokeThickness="1.5"/>
                                    <Path Data="M8,2 L8,5"
                                          Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="2"
                                          StrokeLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Border>

                        <StackPanel Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Monozukuri" Classes="launcher-hero-title"/>
                                <Border Background="{StaticResource Surface2Brush}"
                                        BorderBrush="{StaticResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="8,3">
                                    <TextBlock x:Name="LauncherVersionTextBlock"
                                               Text="v1.0"
                                               Classes="launcher-version-badge"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Kaizen DSP Asset Creator"
                                       Classes="launcher-hero-tagline"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button x:Name="BrowseProjectButton"
                            Content="Browse..."
                            MinWidth="92"
                            Padding="12,8"/>
                    <Button x:Name="OpenSelectedProjectButton"
                            Content="Open Selected"
                            MinWidth="118"
                            Padding="12,8"/>
                    <Button x:Name="NewProjectButton"
                            MinWidth="128"
                            Padding="14,8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="16" Height="16">
                                    <Path Data="M8,2 L8,14 M2,8 L14,8"
                                          Stroke="{StaticResource TextPrimaryBrush}"
                                          StrokeThickness="2"
                                          StrokeLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="New Project"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource Surface0Brush}"
                Padding="24,16">
            <Grid>
                <ListBox x:Name="ProjectListBox">
                    <ListBox.ItemContainerTheme>
                        <StaticResource ResourceKey="ProjectListBoxItemTheme"/>
                    </ListBox.ItemContainerTheme>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ProjectCardBorder"
                                    Background="{StaticResource Surface1Brush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14"
                                    Margin="0,0,0,10"
                                    Cursor="Hand">
                                <Grid ColumnDefinitions="140,*" ColumnSpacing="20">
                                    <Border Grid.Column="0"
                                            Width="140"
                                            Height="140"
                                            CornerRadius="6"
                                            ClipToBounds="True"
                                            Background="{StaticResource Surface2Brush}"
                                            BorderBrush="{StaticResource BorderDefaultBrush}"
                                            BorderThickness="1">
                                        <Panel>
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasThumbnail}"/>
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Spacing="4"
                                                        IsVisible="{Binding ShowPlaceholder}">
                                                <Viewbox Width="28" Height="28">
                                                    <Canvas Width="16" Height="16">
                                                        <Ellipse Width="14"
                                                                 Height="14"
                                                                 Canvas.Left="1"
                                                                 Canvas.Top="1"
                                                                 Stroke="{StaticResource TextTertiaryBrush}"
                                                                 StrokeThickness="1.2"/>
                                                        <Path Data="M8,2 L8,5"
                                                              Stroke="{StaticResource TextTertiaryBrush}"
                                                              StrokeThickness="1.5"
                                                              StrokeLineCap="Round"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="No Preview"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Panel>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Spacing="4">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Classes="launcher-card-title"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding SavedDisplay}"
                                                   Classes="launcher-card-meta"/>
                                        <TextBlock Text="{Binding FilePath}"
                                                   Classes="launcher-card-path"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel x:Name="EmptyStatePanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12"
                            IsVisible="False">
                    <Border Width="80"
                            Height="80"
                            CornerRadius="18"
                            Background="{StaticResource Surface2Brush}"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Center">
                        <Viewbox Width="40" Height="40" Margin="20">
                            <Canvas Width="16" Height="16">
                                <Ellipse Width="14"
                                         Height="14"
                                         Canvas.Left="1"
                                         Canvas.Top="1"
                                         Stroke="{StaticResource TextTertiaryBrush}"
                                         StrokeThickness="1.5"/>
                                <Path Data="M8,2 L8,5"
                                      Stroke="{StaticResource AccentBrush}"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <TextBlock Text="No projects yet" Classes="launcher-empty-title"/>
                    <TextBlock Text="Create a new project to start rendering knobs, switches, sliders, and more."
                               Classes="launcher-empty-body"/>

                    <Button x:Name="EmptyStateNewProjectButton"
                            MinWidth="160"
                            Padding="16,10"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="16" Height="16">
                                    <Path Data="M8,2 L8,14 M2,8 L14,8"
                                          Stroke="{StaticResource TextPrimaryBrush}"
                                          StrokeThickness="2"
                                          StrokeLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Create Your First Project"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource Surface1Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <TextBlock x:Name="LauncherStatusTextBlock"
                           Grid.Column="0"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center"
                           Text=""/>
                <TextBlock Grid.Column="1"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center"
                           Text="Double-click a project to open"/>
            </Grid>
        </Border>
    </Grid>
</Window>
