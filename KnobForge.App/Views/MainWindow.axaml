<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:KnobForge.App.Controls"
    xmlns:colorpicker="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
    xmlns:scene="using:KnobForge.Core.Scene"
    x:Class="KnobForge.App.Views.MainWindow"
    Width="1220"
    Height="760"
    Title="Monozukuri">
    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0"
                Background="{StaticResource Surface0Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <Border Background="{StaticResource Surface0Brush}"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,4">
                        <TextBlock VerticalAlignment="Center"
                                   Classes="title"
                                   Text="Monozukuri"/>

                    </Border>
                    <TextBlock x:Name="TopProjectStatusText"
                               VerticalAlignment="Center"
                               Classes="hint"
                               Text="Project: Untitled"
                               />

                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button x:Name="NewProjectButton"
                            Content="New"
                            MinWidth="72"
                            ToolTip.Tip="Open a new Monozukuri window"/>

                    <Button x:Name="ChangeProjectTypeButton"
                            Content="Change type..."
                            MinWidth="140"
                            ToolTip.Tip="Switch this project between Rotary Knob, Flip Switch, Thumb Slider, or Push Button"/>

                    <Button x:Name="OpenProjectButton"
                            Content="Open..."
                            MinWidth="100"
                            ToolTip.Tip="Open an existing .knob project"/>

                    <Button x:Name="SaveProjectButton"
                            Content="Save"
                            MinWidth="72"
                            ToolTip.Tip="Save current project"/>

                    <Button x:Name="SaveProjectAsButton"
                            Content="Save as..."
                            MinWidth="140"
                            ToolTip.Tip="Save current project to a new file"/>

                    <Button x:Name="RenderButton"
                            Content="Render..."
                            MinWidth="100"
                            ToolTip.Tip="Open spritesheet render window"/>

                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource Surface0Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid ColumnDefinitions="Auto,Auto,*"
                  ColumnSpacing="8"
                  VerticalAlignment="Center">
                <Border Background="{StaticResource Surface1Brush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4">
                    <TextBlock x:Name="ContextStripNodeText"
                               Classes="hint"
                               Text="Node: Model"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                </Border>
                <Border Grid.Column="1"
                        Background="{StaticResource Surface1Brush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4">
                    <TextBlock x:Name="ContextStripToolText"
                               Classes="hint"
                               Text="Tool: View"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                </Border>
                <TextBlock x:Name="ContextStripHintText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Classes="hint"
                           Text="Tip: Select a node to focus inspector controls."
                           TextTrimming="CharacterEllipsis"/>

            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid x:Name="WorkspaceContentGrid" ColumnDefinitions="240,Auto,*,Auto,360">
            <Border Grid.Column="0"
                    Background="{StaticResource Surface1Brush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,0"
                    Padding="6"
                    MinWidth="160"
                    MaxWidth="400">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Classes="title"
                               Text="Scene"
                               FontWeight="SemiBold"
                               Margin="4"/>


                    <ListBox Grid.Row="1"
                             x:Name="SceneListBox"
                             Background="{StaticResource Surface1Brush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderThickness="0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />

                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>

                                <Setter Property="Padding" Value="0"/>

                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="scene:SceneNode">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="4,2"/>

                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                         Width="4"
                         Background="Transparent"
                         ResizeDirection="Columns"
                         ResizeBehavior="PreviousAndNext"/>

            <Border x:Name="ViewportHostBorder" Grid.Column="2" ClipToBounds="True">
                <Grid>
                    <controls:MetalViewport x:Name="MetalViewport"
                                            IsVisible="True"
                                            ZIndex="0"/>

                    <Border x:Name="ViewportOverlay"
                            ZIndex="10"
                            IsHitTestVisible="True"
                            Focusable="True"
                            Background="Transparent"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3"
                         Width="4"
                         Background="Transparent"
                         ResizeDirection="Columns"
                         ResizeBehavior="PreviousAndNext"/>

            <Border Grid.Column="4"
                    Background="{StaticResource Surface1Brush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,0"
                    Padding="10"
                    MinWidth="280"
                    MaxWidth="520">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="6" Margin="0,0,0,4">
                        <TextBox Grid.Column="0"
                                 x:Name="InspectorSearchTextBox"
                                 Watermark="Search settings..."
                                 Height="28"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <Button x:Name="UndoButton" Content="Undo" MinWidth="52" Padding="6,3"/>
                            <Button x:Name="RedoButton" Content="Redo" MinWidth="52" Padding="6,3"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               x:Name="RuntimeDiagnosticsText"
                               Margin="0,0,0,6"
                               Classes="hint"
                               Text="fps -- | frame -- ms | paint -- ms"/>

                    <TabControl Grid.Row="2" x:Name="InspectorTabControl">
                    <TabItem x:Name="LightingTabItem" Header="Lighting">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10" Margin="4">
                                <Expander Header="Mode" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Mode"/>
                                            <ComboBox Grid.Column="1" x:Name="LightingModeCombo"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Lights" IsExpanded="True">
                                    <StackPanel Spacing="8" Margin="0,6,0,0">
                                        <ListBox x:Name="LightListBox" Height="120"/>

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button x:Name="AddLightButton" Content="Add" MinWidth="72"/>

                                            <Button x:Name="RemoveLightButton" Content="Delete" MinWidth="72"/>

                                            <Button x:Name="CenterLightButton" Content="Center" MinWidth="72"/>

                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Transform" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Type"/>
                                            <ComboBox Grid.Column="1" x:Name="LightTypeCombo"/>
                                        </Grid>


                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="X"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="LightXInput" Minimum="-2000" Maximum="2000" Step="1" DecimalPlaces="0"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Y"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="LightYInput" Minimum="-2000" Maximum="2000" Step="1" DecimalPlaces="0"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Z"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="LightZInput" Minimum="-3000" Maximum="3000" Step="1" DecimalPlaces="0"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Direction"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="DirectionInput" Minimum="0" Maximum="360" Step="0.1" DecimalPlaces="1" Suffix=" deg"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Intensity" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Intensity"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="IntensityInput" Minimum="0" Maximum="3" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Falloff"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="FalloffInput" Minimum="0" Maximum="3" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Color · Advanced" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0"
                                                       Classes="param-label"
                                                       Text="Color"
                                                       VerticalAlignment="Top"
                                                       Margin="0,6,0,0"/>
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <Grid ColumnDefinitions="18,*">
                                                    <TextBlock Grid.Column="0" Text="R" Classes="channel-r"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="LightRInput" Minimum="0" Maximum="255" Step="1" DecimalPlaces="0"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="18,*">
                                                    <TextBlock Grid.Column="0" Text="G" Classes="channel-g"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="LightGInput" Minimum="0" Maximum="255" Step="1" DecimalPlaces="0"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="18,*">
                                                    <TextBlock Grid.Column="0" Text="B" Classes="channel-b"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="LightBInput" Minimum="0" Maximum="255" Step="1" DecimalPlaces="0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Artistic · Advanced" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Diffuse boost"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="DiffuseBoostInput" Minimum="0" Maximum="3" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Specular boost"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="SpecularBoostInput" Minimum="0" Maximum="3" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Specular power"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="SpecularPowerInput" Minimum="1" Maximum="256" Step="0.1" DecimalPlaces="1"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Camera" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <TextBlock Classes="hint"
                                                   Text="Cmd+LMB: orbit, MMB: pan, Wheel: zoom, R: reset"
                                                   TextWrapping="Wrap"/>
                                        <Button x:Name="ResetViewButton" Content="Reset view" MinWidth="100"/>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="ModelTabItem" Header="Model">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10" Margin="4">
                                <TextBlock x:Name="NodeInspectorContextText"
                                           Classes="hint"
                                           Text="Selected: Model"
                                           />


                                <Expander x:Name="NodeReferenceProfilesExpander" Header="Reference profiles" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Reference style"/>
                                            <ComboBox Grid.Column="1" x:Name="ReferenceStyleCombo"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Save current as"/>
                                            <TextBox Grid.Column="1" x:Name="ReferenceStyleSaveNameTextBox"
                                                     Watermark="My Custom Knob"/>
                                        </Grid>

                                        <Button x:Name="SaveReferenceProfileButton"
                                                Content="Save profile"
                                                MinWidth="140"/>

                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeTransformExpander" Header="Transform" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Rotation"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="RotationInput" Minimum="0" Maximum="360" Step="0.1" DecimalPlaces="1" Suffix=" deg"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeBodyShapeExpander" Header="Shape" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Body style"/>
                                            <ComboBox Grid.Column="1" x:Name="BodyStyleCombo"/>
                                        </Grid>


                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Radius"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ModelRadiusInput" Minimum="40" Maximum="500" Step="1" DecimalPlaces="0"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Height"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ModelHeightInput" Minimum="20" Maximum="320" Step="1" DecimalPlaces="0"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Top scale"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ModelTopScaleInput" Minimum="0.30" Maximum="1.30" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Bevel"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ModelBevelInput" Minimum="0" Maximum="120" Step="1" DecimalPlaces="0"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Bevel curve"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="BevelCurveInput" Minimum="0.4" Maximum="3" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Crown profile" ToolTip.Tip="Negative = concave, positive = convex"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CrownProfileInput" Minimum="-1" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Body taper"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="BodyTaperInput" Minimum="-0.35" Maximum="0.35" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Body bulge"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="BodyBulgeInput" Minimum="-0.35" Maximum="0.35" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Segments"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ModelSegmentsInput" Minimum="12" Maximum="180" Step="1" DecimalPlaces="0"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeSliderAssemblyExpander" Header="Slider assembly" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Expander Header="Setup" IsExpanded="True">
                                            <StackPanel Spacing="6" Margin="0,6,0,0">
                                                <TextBlock Text="Backplate and thumb mesh configuration." Classes="hint"/>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Mode"/>
                                                    <ComboBox Grid.Column="1" x:Name="SliderAssemblyModeCombo"/>
                                                </Grid>

                                                <TextBlock Classes="section-tag" Text="MESH SOURCES"/>
                                                <DockPanel LastChildFill="True">
                                                    <Button x:Name="RefreshSliderLibraryButton"
                                                            Content="↻"
                                                            ToolTip.Tip="Refresh mesh library"
                                                            DockPanel.Dock="Right"
                                                            Margin="8,0,0,0"
                                                            MinWidth="32"
                                                            Padding="6,4"/>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Backplate mesh"/>
                                                        <ComboBox Grid.Column="1" x:Name="SliderBackplateMeshCombo"/>
                                                    </Grid>
                                                </DockPanel>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Thumb mesh"/>
                                                    <ComboBox Grid.Column="1" x:Name="SliderThumbMeshCombo"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Thumb profile"/>
                                                    <ComboBox Grid.Column="1" x:Name="SliderThumbProfileCombo"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Track style"/>
                                                    <ComboBox Grid.Column="1" x:Name="SliderTrackStyleCombo"/>
                                                </Grid>

                                            </StackPanel>
                                        </Expander>

                                        <Expander Header="Geometry · Advanced" IsExpanded="False">
                                            <StackPanel Spacing="6" Margin="0,6,0,0">
                                                <TextBlock Classes="section-tag" Text="BACKPLATE"/>
                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Backplate width" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderBackplateWidthInput" Minimum="0" Maximum="2000" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Backplate height" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderBackplateHeightInput" Minimum="0" Maximum="3000" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Backplate thickness" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderBackplateThicknessInput" Minimum="0" Maximum="400" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Track width" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderTrackWidthInput" Minimum="0" Maximum="1200" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Track depth" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderTrackDepthInput" Minimum="0" Maximum="160" Step="0.1" DecimalPlaces="2" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Rail height" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderRailHeightInput" Minimum="0" Maximum="120" Step="0.1" DecimalPlaces="2" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Rail spacing" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderRailSpacingInput" Minimum="0" Maximum="1200" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <TextBlock Classes="section-tag" Text="THUMB"/>
                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Thumb width" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderThumbWidthInput" Minimum="0" Maximum="1200" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Thumb height" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderThumbHeightInput" Minimum="0" Maximum="1600" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Thumb depth" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderThumbDepthInput" Minimum="0" Maximum="1200" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Ridge count" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderThumbRidgeCountInput" Minimum="0" Maximum="16" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Ridge depth" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderThumbRidgeDepthInput" Minimum="0" Maximum="120" Step="0.1" DecimalPlaces="2" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Corner radius" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="SliderThumbCornerRadiusInput" Minimum="0" Maximum="120" Step="0.1" DecimalPlaces="2" Suffix=" px"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeToggleAssemblyExpander" Header="Toggle assembly" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Expander Header="Setup" IsExpanded="True">
                                            <StackPanel Spacing="6" Margin="0,6,0,0">
                                                <TextBlock Text="Base and lever mesh configuration with state control." Classes="hint"/>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Mode"/>
                                                    <ComboBox Grid.Column="1" x:Name="ToggleAssemblyModeCombo"/>
                                                </Grid>

                                                <TextBlock Classes="section-tag" Text="MESH SOURCES"/>
                                                <DockPanel LastChildFill="True">
                                                    <Button x:Name="RefreshToggleLibraryButton"
                                                            Content="↻"
                                                            ToolTip.Tip="Refresh mesh library"
                                                            DockPanel.Dock="Right"
                                                            Margin="8,0,0,0"
                                                            MinWidth="32"
                                                            Padding="6,4"/>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Base mesh"/>
                                                        <ComboBox Grid.Column="1" x:Name="ToggleBaseMeshCombo"/>
                                                    </Grid>
                                                </DockPanel>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Lever mesh"/>
                                                    <ComboBox Grid.Column="1" x:Name="ToggleLeverMeshCombo"/>
                                                </Grid>


                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="States"/>
                                                    <ComboBox Grid.Column="1" x:Name="ToggleStateCountCombo"/>
                                                </Grid>


                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="State"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleStateIndexInput" Minimum="0" Maximum="2" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Max angle"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleMaxAngleInput" Minimum="5" Maximum="85" Step="0.1" DecimalPlaces="1" Suffix=" deg"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander>

                                        <Expander Header="Base &amp; plate · Advanced" IsExpanded="False">
                                            <StackPanel Spacing="6" Margin="0,6,0,0">
                                                <TextBlock Classes="section-tag" Text="PLATE"/>
                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Plate width" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="TogglePlateWidthInput" Minimum="0" Maximum="2200" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Plate height" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="TogglePlateHeightInput" Minimum="0" Maximum="2600" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Plate thickness" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="TogglePlateThicknessInput" Minimum="0" Maximum="500" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Plate offset Y"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="TogglePlateOffsetYInput" Minimum="-1200" Maximum="1200" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Plate offset Z"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="TogglePlateOffsetZInput" Minimum="-1200" Maximum="1200" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <TextBlock Classes="section-tag" Text="BUSHING"/>
                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Bushing radius" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleBushingRadiusInput" Minimum="0" Maximum="500" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Bushing height" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleBushingHeightInput" Minimum="0" Maximum="500" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Sides"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleBushingSidesInput" Minimum="3" Maximum="32" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Lower shape"/>
                                                    <ComboBox Grid.Column="1" x:Name="ToggleLowerBushingShapeCombo"/>
                                                </Grid>


                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Upper shape"/>
                                                    <ComboBox Grid.Column="1" x:Name="ToggleUpperBushingShapeCombo"/>
                                                </Grid>


                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Radius scale"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleLowerBushingRadiusScaleInput" Minimum="0.25" Maximum="4" Step="0.01" DecimalPlaces="2" Suffix="x"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Height ratio"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleLowerBushingHeightRatioInput" Minimum="0.05" Maximum="2" Step="0.01" DecimalPlaces="2" Suffix="x"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Radius scale"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleUpperBushingRadiusScaleInput" Minimum="0.25" Maximum="4" Step="0.01" DecimalPlaces="2" Suffix="x"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Height ratio"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleUpperBushingHeightRatioInput" Minimum="0.05" Maximum="2" Step="0.01" DecimalPlaces="2" Suffix="x"/>
                                                </Grid>

                                                <TextBlock Classes="section-tag" Text="SURFACE"/>
                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Knurl amount"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleUpperBushingKnurlAmountInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Knurl density"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleUpperBushingKnurlDensityInput" Minimum="3" Maximum="96" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Knurl depth"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleUpperBushingKnurlDepthInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Separator Margin="0,4,0,4"/>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Aniso strength"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleUpperBushingAnisotropyStrengthInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Aniso density"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleUpperBushingAnisotropyDensityInput" Minimum="3" Maximum="128" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Aniso angle"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleUpperBushingAnisotropyAngleInput" Minimum="-180" Maximum="180" Step="0.1" DecimalPlaces="1" Suffix=" deg"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Surface character"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleUpperBushingSurfaceCharacterInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <CheckBox x:Name="ToggleInvertBaseWindingCheckBox"
                                                          Content="Invert winding"/>

                                            </StackPanel>
                                        </Expander>

                                        <Expander Header="Lever &amp; pivot · Advanced" IsExpanded="False">
                                            <StackPanel Spacing="6" Margin="0,6,0,0">
                                                <TextBlock Classes="section-tag" Text="HOUSING"/>
                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Housing radius" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="TogglePivotHousingRadiusInput" Minimum="0" Maximum="500" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Housing depth" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="TogglePivotHousingDepthInput" Minimum="0" Maximum="500" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Housing bevel" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="TogglePivotHousingBevelInput" Minimum="0" Maximum="250" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Ball radius" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="TogglePivotBallRadiusInput" Minimum="0" Maximum="500" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Clearance"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="TogglePivotClearanceInput" Minimum="0" Maximum="128" Step="0.01" DecimalPlaces="2" Suffix=" px"/>
                                                </Grid>

                                                <TextBlock Classes="section-tag" Text="LEVER"/>
                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Lever length" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleLeverLengthInput" Minimum="0" Maximum="2200" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Bottom radius" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleLeverRadiusInput" Minimum="0" Maximum="500" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Top radius" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleLeverTopRadiusInput" Minimum="0" Maximum="500" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Sides"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleLeverSidesInput" Minimum="6" Maximum="64" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Pivot offset"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleLeverPivotOffsetInput" Minimum="-800" Maximum="800" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <TextBlock Classes="section-tag" Text="TIP"/>
                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Tip radius" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipRadiusInput" Minimum="0" Maximum="500" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Tip latitude segments"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipLatitudeSegmentsInput" Minimum="4" Maximum="64" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Tip longitude segments"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipLongitudeSegmentsInput" Minimum="6" Maximum="128" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <CheckBox x:Name="ToggleInvertLeverWindingCheckBox"
                                                          Content="Invert winding"/>

                                            </StackPanel>
                                        </Expander>

                                        <Expander Header="Tip sleeve · Advanced" IsExpanded="False">
                                            <StackPanel Spacing="6" Margin="0,6,0,0">
                                                <CheckBox x:Name="ToggleTipSleeveEnabledCheckBox"
                                                          Content="Enable sleeve"/>


                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Length" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveLengthInput" Minimum="0" Maximum="900" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Thickness" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveThicknessInput" Minimum="0" Maximum="220" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Outer radius" ToolTip.Tip="Set to 0 for automatic sizing"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveOuterRadiusInput" Minimum="0" Maximum="500" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Coverage"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveCoverageInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Sides"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveSidesInput" Minimum="6" Maximum="64" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Style"/>
                                                    <ComboBox Grid.Column="1" x:Name="ToggleTipSleeveStyleCombo"/>
                                                </Grid>


                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Tip style"/>
                                                    <ComboBox Grid.Column="1" x:Name="ToggleTipSleeveTipStyleCombo"/>
                                                </Grid>


                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Pattern count"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleevePatternCountInput" Minimum="3" Maximum="64" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Pattern depth"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleevePatternDepthInput" Minimum="0" Maximum="0.9" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Tip amount"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveTipAmountInput" Minimum="0" Maximum="0.95" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0"
                                                               Classes="param-label"
                                                               Text="Color"
                                                               VerticalAlignment="Top"
                                                               Margin="0,6,0,0"/>
                                                    <StackPanel Grid.Column="1" Spacing="3">
                                                        <Grid ColumnDefinitions="18,*">
                                                            <TextBlock Grid.Column="0" Text="R" Classes="channel-r"/>
                                                            <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveColorRInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                        </Grid>
                                                        <Grid ColumnDefinitions="18,*">
                                                            <TextBlock Grid.Column="0" Text="G" Classes="channel-g"/>
                                                            <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveColorGInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                        </Grid>
                                                        <Grid ColumnDefinitions="18,*">
                                                            <TextBlock Grid.Column="0" Text="B" Classes="channel-b"/>
                                                            <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveColorBInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Metallic"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveMetallicInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Roughness"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveRoughnessInput" Minimum="0.04" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Pearlescence"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleevePearlescenceInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Diffuse strength"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveDiffuseStrengthInput" Minimum="0" Maximum="4" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Specular strength"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveSpecularStrengthInput" Minimum="0" Maximum="4" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Rust"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveRustInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Wear"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveWearInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Gunk"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="ToggleTipSleeveGunkInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodePushButtonAssemblyExpander" Header="Push button assembly" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Expander Header="Setup" IsExpanded="True">
                                            <StackPanel Spacing="6" Margin="0,6,0,0">
                                                <TextBlock Text="Cap, bezel, skirt, and imported mesh configuration for button assemblies." Classes="hint"/>

                                                <TextBlock Classes="section-tag" Text="MESH SOURCES"/>

                                                <DockPanel LastChildFill="True">
                                                    <Button x:Name="RefreshPushButtonLibraryButton"
                                                            Content="↻"
                                                            ToolTip.Tip="Refresh mesh library"
                                                            DockPanel.Dock="Right"
                                                            Margin="8,0,0,0"
                                                            MinWidth="32"
                                                            Padding="6,4"/>
                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Base mesh"/>
                                                        <ComboBox Grid.Column="1" x:Name="PushButtonBaseMeshCombo"/>
                                                    </Grid>
                                                </DockPanel>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Cap mesh"/>
                                                    <ComboBox Grid.Column="1" x:Name="PushButtonCapMeshCombo"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Cap profile"/>
                                                    <ComboBox Grid.Column="1" x:Name="PushButtonCapProfileCombo"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Bezel profile"/>
                                                    <ComboBox Grid.Column="1" x:Name="PushButtonBezelProfileCombo"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Skirt style"/>
                                                    <ComboBox Grid.Column="1" x:Name="PushButtonSkirtStyleCombo"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Press amount"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="PushButtonPressAmountInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander>

                                        <Expander Header="Geometry · Advanced" IsExpanded="False">
                                            <StackPanel Spacing="6" Margin="0,6,0,0">
                                                <TextBlock Classes="section-tag" Text="CAP"/>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Cap overhang"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="PushButtonCapOverhangInput" Minimum="0" Maximum="64" Step="0.1" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Cap segments"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="PushButtonCapSegmentsInput" Minimum="0" Maximum="128" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <TextBlock Classes="section-tag" Text="BEZEL"/>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Chamfer size"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="PushButtonBezelChamferSizeInput" Minimum="0" Maximum="32" Step="0.1" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Bezel segments"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="PushButtonBezelSegmentsInput" Minimum="0" Maximum="128" Step="1" DecimalPlaces="0"/>
                                                </Grid>

                                                <TextBlock Classes="section-tag" Text="SKIRT"/>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Skirt height"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="PushButtonSkirtHeightInput" Minimum="0" Maximum="32" Step="0.1" DecimalPlaces="2"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Skirt radius"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="PushButtonSkirtRadiusInput" Minimum="0" Maximum="64" Step="0.1" DecimalPlaces="2"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeSpiralRidgeExpander" Header="Spiral ridge" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Ridge height"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="SpiralRidgeHeightInput" Minimum="0" Maximum="24" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Ridge width"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="SpiralRidgeWidthInput" Minimum="0.4" Maximum="30" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Spiral turns"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="SpiralTurnsInput" Minimum="150" Maximum="250" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeGripExpander" Header="Grip" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Grip style"/>
                                            <ComboBox Grid.Column="1" x:Name="GripStyleCombo"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Grip type"/>
                                            <ComboBox Grid.Column="1" x:Name="GripTypeCombo"/>
                                        </Grid>


                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Grip start"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="GripStartInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Grip height"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="GripHeightInput" Minimum="0.05" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Knurl density"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="GripDensityInput" Minimum="4" Maximum="320" Step="0.1" DecimalPlaces="1"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Knurl pitch"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="GripPitchInput" Minimum="0.2" Maximum="24" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Knurl depth"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="GripDepthInput" Minimum="0" Maximum="20" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Knurl width"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="GripWidthInput" Minimum="0.05" Maximum="3" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Knurl sharpness"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="GripSharpnessInput" Minimum="0.5" Maximum="8" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeCollarExpander" Header="Collar" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <CheckBox x:Name="CollarEnabledCheckBox"
                                                  Content="Enable"/>

                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Left"
                                                       Classes="param-label"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       Text="Preset"/>
                                            <Button x:Name="RefreshCollarLibraryButton"
                                                    Content="Refresh library"
                                                    DockPanel.Dock="Right"
                                                    Margin="8,0,0,0"
                                                    MinWidth="140"/>

                                            <ComboBox x:Name="CollarPresetCombo" MaxDropDownHeight="420" x:CompileBindings="False">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <Border Width="34"
                                                                    Height="34"
                                                                    CornerRadius="4"
                                                                    BorderBrush="{StaticResource BorderStrongBrush}"
                                                                    BorderThickness="1"
                                                                    IsVisible="{Binding HasThumbnail}">
                                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>

                                                            </Border>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       VerticalAlignment="Center"
                                                                       TextWrapping="Wrap"/>

                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </DockPanel>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Mesh path (.glb/.stl)"/>
                                            <TextBox Grid.Column="1" x:Name="CollarMeshPathTextBox"
                                                     Watermark="/Users/.../ouroboros.glb"/>
                                        </Grid>

                                        <TextBlock x:Name="CollarResolvedMeshPathText"
                                                   Classes="hint"
                                                   Text="Resolved source:"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock x:Name="CollarMeshPathStatusText"
                                                   Classes="hint"
                                                   Text="Path status:"
                                                   TextWrapping="Wrap"/>


                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Scale"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarScaleInput" Minimum="0.05" Maximum="4" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Body length"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarBodyLengthInput" Minimum="0.6" Maximum="2.4" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Body thickness"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarBodyThicknessInput" Minimum="0.5" Maximum="2.5" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Head length"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarHeadLengthInput" Minimum="0.5" Maximum="2.5" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Head thickness"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarHeadThicknessInput" Minimum="0.5" Maximum="2.8" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Rotation"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarRotateInput" Minimum="-180" Maximum="180" Step="0.1" DecimalPlaces="1" Suffix=" deg"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Mirror flip"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                <CheckBox x:Name="CollarMirrorXCheckBox" Content="X"/>
                                                <CheckBox x:Name="CollarMirrorYCheckBox" Content="Y"/>
                                                <CheckBox x:Name="CollarMirrorZCheckBox" Content="Z"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Offset X"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarOffsetXInput" Minimum="-1.5" Maximum="1.5" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Offset Y"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarOffsetYInput" Minimum="-1.5" Maximum="1.5" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Elevation"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarElevationInput" Minimum="-1.5" Maximum="1.5" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Inflate"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarInflateInput" Minimum="-0.2" Maximum="0.2" Step="0.001" DecimalPlaces="3"/>
                                        </Grid>

                                        <Separator Margin="0,4,0,4"/>

                                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0"
                                                       Classes="param-label"
                                                       Text="Base color"
                                                       VerticalAlignment="Top"
                                                       Margin="0,6,0,0"/>
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <Grid ColumnDefinitions="18,*">
                                                    <TextBlock Grid.Column="0" Text="R" Classes="channel-r"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="CollarMaterialBaseRInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="18,*">
                                                    <TextBlock Grid.Column="0" Text="G" Classes="channel-g"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="CollarMaterialBaseGInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="18,*">
                                                    <TextBlock Grid.Column="0" Text="B" Classes="channel-b"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="CollarMaterialBaseBInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Metallic"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarMaterialMetallicInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Roughness"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarMaterialRoughnessInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Pearlescence"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarMaterialPearlescenceInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Rust"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarMaterialRustInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Wear"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarMaterialWearInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Gunk"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="CollarMaterialGunkInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeRotaryIndicatorExpander" Header="Indicator" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                            <CheckBox x:Name="IndicatorEnabledCheckBox"
                                                      Content="Enable"/>

                                            <CheckBox x:Name="IndicatorCadWallsCheckBox"
                                                      Content="CAD walls"/>


                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Shape"/>
                                                <ComboBox Grid.Column="1" x:Name="IndicatorShapeCombo"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Relief"/>
                                                <ComboBox Grid.Column="1" x:Name="IndicatorReliefCombo"/>
                                            </Grid>


                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Profile"/>
                                                <ComboBox Grid.Column="1" x:Name="IndicatorProfileCombo"/>
                                            </Grid>


                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Width"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorWidthInput" Minimum="0.005" Maximum="0.35" Step="0.001" DecimalPlaces="3"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Length"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorLengthInput" Minimum="0.05" Maximum="0.8" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Position"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorPositionInput" Minimum="0.05" Maximum="0.9" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Thickness"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorThicknessInput" Minimum="0" Maximum="0.08" Step="0.001" DecimalPlaces="3"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Edge roundness"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorRoundnessInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Color blend"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorColorBlendInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0"
                                                           Classes="param-label"
                                                           Text="Indicator color"
                                                           VerticalAlignment="Top"
                                                           Margin="0,6,0,0"/>
                                                <StackPanel Grid.Column="1" Spacing="3">
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="R" Classes="channel-r"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorColorRInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="G" Classes="channel-g"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorColorGInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="B" Classes="channel-b"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorColorBInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeIndicatorLightAssemblyExpander" Header="Indicator light assembly" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                            <TextBlock Text="Indicator assembly" Classes="section-title"/>

                                            <CheckBox x:Name="IndicatorAssemblyEnabledCheckBox"
                                                      Content="Enable"/>


                                            <Expander Header="Quick controls" IsExpanded="True">
                                                <StackPanel Spacing="6" Margin="0,6,0,0">
                                                    <TextBlock Text="Fast controls for on/off tuning." Classes="hint"/>

                                                    <CheckBox x:Name="IndicatorQuickLightOnCheckBox"
                                                              Content="Light on"/>


                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Brightness"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorQuickBrightnessInput" Minimum="0" Maximum="4" Step="0.01" DecimalPlaces="2" Suffix="x"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Glow"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorQuickGlowInput" Minimum="0" Maximum="4" Step="0.01" DecimalPlaces="2" Suffix="x"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Expander>

                                            <Expander Header="Geometry · Advanced" IsExpanded="False">
                                                <StackPanel Spacing="6" Margin="0,6,0,0">
                                                    <TextBlock Classes="section-tag" Text="BASE"/>
                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Base width"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorBaseWidthInput" Minimum="24" Maximum="1024" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Base height"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorBaseHeightInput" Minimum="24" Maximum="1024" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Base thickness"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorBaseThicknessInput" Minimum="2" Maximum="256" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <TextBlock Classes="section-tag" Text="HOUSING"/>
                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Housing radius"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorHousingRadiusInput" Minimum="4" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Housing height"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorHousingHeightInput" Minimum="2" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <TextBlock Classes="section-tag" Text="LENS"/>
                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Lens radius"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensRadiusInput" Minimum="2" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Lens height"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensHeightInput" Minimum="2" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Latitude segments"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensLatitudeSegmentsInput" Minimum="4" Maximum="64" Step="1" DecimalPlaces="0"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Longitude segments"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensLongitudeSegmentsInput" Minimum="6" Maximum="96" Step="1" DecimalPlaces="0"/>
                                                    </Grid>

                                                    <TextBlock Classes="section-tag" Text="REFLECTOR"/>
                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Base radius"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorReflectorBaseRadiusInput" Minimum="1" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Top radius"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorReflectorTopRadiusInput" Minimum="1" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Reflector depth"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorReflectorDepthInput" Minimum="1" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <TextBlock Classes="section-tag" Text="EMITTER"/>
                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Emitter radius"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterRadiusInput" Minimum="0.5" Maximum="256" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Emitter spread"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSpreadInput" Minimum="0" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Emitter depth"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterDepthInput" Minimum="-256" Maximum="256" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Emitter count"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterCountInput" Minimum="1" Maximum="8" Step="1" DecimalPlaces="0"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Radial segments"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorRadialSegmentsInput" Minimum="8" Maximum="96" Step="1" DecimalPlaces="0"/>
                                                    </Grid>

                                                    <Button x:Name="IndicatorAssemblyResetDefaultsButton"
                                                            Content="Reset defaults"
                                                            MinWidth="140"/>

                                                </StackPanel>
                                            </Expander>

                                            <Expander Header="Lens material · Advanced" IsExpanded="False">
                                                <StackPanel Spacing="6" Margin="0,6,0,0">
                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Transmission"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensTransmissionInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="IOR"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensIorInput" Minimum="1" Maximum="2.5" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Thickness"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensThicknessInput" Minimum="0" Maximum="10" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Absorption"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensAbsorptionInput" Minimum="0" Maximum="8" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Surface roughness"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensSurfaceRoughnessInput" Minimum="0.04" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Surface specular"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensSurfaceSpecularInput" Minimum="0" Maximum="2.5" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0"
                                                                   Classes="param-label"
                                                                   Text="Tint"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,6,0,0"/>
                                                        <StackPanel Grid.Column="1" Spacing="3">
                                                            <Grid ColumnDefinitions="18,*">
                                                                <TextBlock Grid.Column="0" Text="R" Classes="channel-r"/>
                                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensTintRInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                            </Grid>
                                                            <Grid ColumnDefinitions="18,*">
                                                                <TextBlock Grid.Column="0" Text="G" Classes="channel-g"/>
                                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensTintGInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                            </Grid>
                                                            <Grid ColumnDefinitions="18,*">
                                                                <TextBlock Grid.Column="0" Text="B" Classes="channel-b"/>
                                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorLensTintBInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button x:Name="IndicatorLensPresetClearButton" Content="Clear lens"/>

                                                        <Button x:Name="IndicatorLensPresetFrostedButton" Content="Frosted"/>

                                                        <Button x:Name="IndicatorLensPresetSaturatedButton" Content="Saturated LED"/>

                                                    </StackPanel>
                                                </StackPanel>
                                            </Expander>

                                            <Expander Header="Dynamic lights · Advanced" IsExpanded="False">
                                                <StackPanel Spacing="6" Margin="0,6,0,0">
                                                    <CheckBox x:Name="IndicatorDynamicLightsEnabledCheckBox"
                                                              Content="Enable"/>


                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Animation mode"/>
                                                        <ComboBox Grid.Column="1" x:Name="IndicatorLightAnimationModeCombo"/>
                                                    </Grid>


                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Animation speed"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLightAnimationSpeedInput" Minimum="0" Maximum="10" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Flicker amount"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLightFlickerAmountInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Flicker dropout"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLightFlickerDropoutInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Flicker smoothing"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLightFlickerSmoothingInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Flicker seed"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorLightFlickerSeedInput" Minimum="1" Maximum="100000" Step="1" DecimalPlaces="0"/>
                                                    </Grid>

                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button x:Name="IndicatorLightPresetNeutralButton" Content="Neutral"/>

                                                        <Button x:Name="IndicatorLightPresetPulseButton" Content="Pulse"/>

                                                        <Button x:Name="IndicatorLightPresetFlickerButton" Content="Flicker"/>

                                                    </StackPanel>
                                                </StackPanel>
                                            </Expander>

                                            <Expander Header="Emitter sources · Advanced" IsExpanded="False">
                                                <StackPanel Spacing="6" Margin="0,6,0,0">
                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Emitter"/>
                                                        <ComboBox Grid.Column="1" x:Name="IndicatorEmitterSourceCombo"/>
                                                    </Grid>

                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button x:Name="IndicatorEmitterSourceMoveUpButton" Content="Move up"/>

                                                        <Button x:Name="IndicatorEmitterSourceMoveDownButton" Content="Move down"/>

                                                        <Button x:Name="IndicatorEmitterSourceAutoPhaseButton" Content="Auto phase"/>

                                                    </StackPanel>
                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Name"/>
                                                        <TextBox Grid.Column="1" x:Name="IndicatorEmitterSourceNameTextBox"/>
                                                    </Grid>

                                                    <CheckBox x:Name="IndicatorEmitterSourceEnabledCheckBox"
                                                              Content="Enabled"/>


                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Phase offset"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSourcePhaseOffsetInput" Minimum="-360" Maximum="360" Step="0.1" DecimalPlaces="1" Suffix=" deg"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Offset X"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSourceXInput" Minimum="-512" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Offset Y"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSourceYInput" Minimum="-512" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Offset Z"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSourceZInput" Minimum="-512" Maximum="512" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Intensity"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSourceIntensityInput" Minimum="0" Maximum="8" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Radius"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSourceRadiusInput" Minimum="4" Maximum="2048" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Classes="param-label" Text="Falloff"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSourceFalloffInput" Minimum="0.05" Maximum="4" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>

                                                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0"
                                                                   Classes="param-label"
                                                                   Text="Color"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,6,0,0"/>
                                                        <StackPanel Grid.Column="1" Spacing="3">
                                                            <Grid ColumnDefinitions="18,*">
                                                                <TextBlock Grid.Column="0" Text="R" Classes="channel-r"/>
                                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSourceRInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                            </Grid>
                                                            <Grid ColumnDefinitions="18,*">
                                                                <TextBlock Grid.Column="0" Text="G" Classes="channel-g"/>
                                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSourceGInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                            </Grid>
                                                            <Grid ColumnDefinitions="18,*">
                                                                <TextBlock Grid.Column="0" Text="B" Classes="channel-b"/>
                                                                <controls:ValueInput Grid.Column="1" x:Name="IndicatorEmitterSourceBInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Expander>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeMaterialExpander" Header="Material" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <StackPanel x:Name="MaterialListPanel"
                                                    Spacing="6"
                                                    IsVisible="False">
                                            <TextBlock Text="Imported materials" Classes="section-title"/>

                                            <ListBox x:Name="MaterialListBox"
                                                     MaxHeight="160"
                                                     Background="{StaticResource Surface2Brush}"
                                                     BorderBrush="{StaticResource BorderDefaultBrush}"
                                                     BorderThickness="1">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid ColumnDefinitions="Auto,*"
                                                              ColumnSpacing="8">
                                                            <Border Width="14"
                                                                    Height="14"
                                                                    CornerRadius="3"
                                                                    VerticalAlignment="Center"
                                                                    Background="{ReflectionBinding SwatchBrush}"
                                                                    BorderBrush="{StaticResource BorderStrongBrush}"
                                                                    BorderThickness="1"/>

                                                            <TextBlock Grid.Column="1"
                                                                       VerticalAlignment="Center"
                                                                       Text="{ReflectionBinding Name}"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Material name"/>
                                                <TextBox Grid.Column="1" x:Name="MaterialNameTextBox"
                                                         Watermark="Material name"/>
                                            </Grid>

                                            <Separator Margin="0,4,0,4"/>

                                        </StackPanel>

                                        <StackPanel x:Name="MaterialRegionPanel"
                                                    Spacing="6">
                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Material region"/>
                                                <ComboBox Grid.Column="1" x:Name="MaterialRegionCombo"/>
                                            </Grid>

                                        </StackPanel>

                                        <StackPanel x:Name="AssemblyMaterialPresetPanel"
                                                    Spacing="6"
                                                    IsVisible="False">
                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Assembly preset"/>
                                                <ComboBox Grid.Column="1" x:Name="AssemblyMaterialPresetCombo"/>
                                            </Grid>
                                            <TextBlock x:Name="AssemblyMaterialPresetHintText"
                                                       Classes="hint"
                                                       Text="Preset overrides manual material values while active."/>
                                        </StackPanel>

                                        <StackPanel x:Name="MaterialManualControlsPanel"
                                                    Spacing="6">
                                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0"
                                                           Classes="param-label"
                                                           Text="Base color"
                                                           VerticalAlignment="Top"
                                                           Margin="0,6,0,0"/>
                                                <StackPanel Grid.Column="1" Spacing="3">
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="R" Classes="channel-r"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="MaterialBaseRInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="G" Classes="channel-g"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="MaterialBaseGInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="B" Classes="channel-b"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="MaterialBaseBInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Metallic"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="MaterialMetallicInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Roughness"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="MaterialRoughnessInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Pearlescence"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="MaterialPearlescenceInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Rust"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="MaterialRustInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Wear"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="MaterialWearInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Gunk"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="MaterialGunkInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Separator Margin="0,4,0,4"/>

                                            <TextBlock Text="Texture maps" Classes="section-title"/>

                                            <TextBlock Text="Albedo map" Classes="param-label"/>

                                            <TextBlock x:Name="MaterialAlbedoMapPathText"
                                                       Classes="hint"
                                                       Text="None"
                                                       TextWrapping="Wrap"/>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button x:Name="MaterialAlbedoMapBrowseButton" Content="Browse..."/>
                                                <Button x:Name="MaterialAlbedoMapClearButton" Content="Clear"/>
                                            </StackPanel>

                                            <TextBlock Text="Normal map" Classes="param-label"/>

                                            <TextBlock x:Name="MaterialNormalMapPathText"
                                                       Classes="hint"
                                                       Text="None"
                                                       TextWrapping="Wrap"/>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button x:Name="MaterialNormalMapBrowseButton" Content="Browse..."/>
                                                <Button x:Name="MaterialNormalMapClearButton" Content="Clear"/>
                                            </StackPanel>
                                            <StackPanel x:Name="MaterialNormalMapStrengthPanel"
                                                        Spacing="6"
                                                        IsVisible="False">
                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Normal strength"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="MaterialNormalMapStrengthInput" Minimum="0" Maximum="2" Step="0.01" DecimalPlaces="2" Suffix="x"/>
                                                </Grid>
                                            </StackPanel>

                                            <TextBlock Text="Roughness map" Classes="param-label"/>

                                            <TextBlock x:Name="MaterialRoughnessMapPathText"
                                                       Classes="hint"
                                                       Text="None"
                                                       TextWrapping="Wrap"/>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button x:Name="MaterialRoughnessMapBrowseButton" Content="Browse..."/>
                                                <Button x:Name="MaterialRoughnessMapClearButton" Content="Clear"/>
                                            </StackPanel>

                                            <TextBlock Text="Metallic map" Classes="param-label"/>

                                            <TextBlock x:Name="MaterialMetallicMapPathText"
                                                       Classes="hint"
                                                       Text="None"
                                                       TextWrapping="Wrap"/>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button x:Name="MaterialMetallicMapBrowseButton" Content="Browse..."/>
                                                <Button x:Name="MaterialMetallicMapClearButton" Content="Clear"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeSurfaceTextureExpander" Header="Surface texture" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Brush strength"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="MaterialBrushStrengthInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Brush density"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="MaterialBrushDensityInput" Minimum="4" Maximum="320" Step="0.1" DecimalPlaces="1"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Surface character"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="MaterialCharacterInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodeMicroDetailExpander" Header="Micro detail · Debug" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <CheckBox x:Name="SpiralNormalInfluenceCheckBox"
                                                  Content="Enable spiral normal influence"/>


                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Basis debug mode"/>
                                            <ComboBox Grid.Column="1" x:Name="BasisDebugModeCombo"/>
                                        </Grid>


                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="LOD fade start"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="MicroLodFadeStartInput" Minimum="0.1" Maximum="10" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="LOD fade end"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="MicroLodFadeEndInput" Minimum="0.1" Maximum="12" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="LOD roughness"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="MicroRoughnessLodBoostInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="BrushTabItem" Header="Brush">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10" Margin="4">
                                <TextBlock Text="LMB: paint, Cmd+LMB: orbit, MMB: pan"
                                           Classes="hint"/>


                                <Expander x:Name="BrushAdvancedExpander" Header="Brush controls" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <CheckBox x:Name="BrushPaintEnabledCheckBox"
                                                  Content="Enable painting"/>


                                        <Border Classes="inset-card">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Paint layers"
                                                           Classes="section-title"/>

                                                <ListBox x:Name="PaintLayerListBox"
                                                         Height="120"/>

                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button x:Name="AddPaintLayerButton"
                                                            Content="Add layer"
                                                            MinWidth="100"/>

                                                    <Button x:Name="DeletePaintLayerButton"
                                                            Content="Delete layer"
                                                            MinWidth="100"/>

                                                </StackPanel>
                                                <TextBox x:Name="PaintLayerNameTextBox"
                                                         Watermark="Selected layer name"/>

                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button x:Name="RenamePaintLayerButton"
                                                            Content="Rename"
                                                            MinWidth="72"/>

                                                    <Button x:Name="ClearPaintLayerFocusButton"
                                                            Content="Show all layers"
                                                            MinWidth="140"/>

                                                </StackPanel>
                                                <CheckBox x:Name="FocusPaintLayerCheckBox"
                                                          Content="Focus layer"/>

                                                <CheckBox x:Name="PaintLayerVisibleCheckBox"
                                                          Content="Visible"/>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Blend"/>
                                                    <ComboBox Grid.Column="1" x:Name="PaintLayerBlendModeCombo"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0" Classes="param-label" Text="Opacity"/>
                                                    <controls:ValueInput Grid.Column="1" x:Name="PaintLayerOpacityInput"
                                                                     Minimum="0"
                                                                     Maximum="1"
                                                                     Step="0.01"
                                                                     DecimalPlaces="2"/>
                                                </Grid>

                                            </StackPanel>
                                        </Border>

                                        <Border Classes="inset-card">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Paint mask resolution"
                                                           Classes="section-title"/>

                                                <ComboBox x:Name="PaintMaskResolutionCombo"/>

                                                <TextBlock x:Name="PaintMaskResolutionMemoryText"
                                                           Classes="hint"/>

                                            </StackPanel>
                                        </Border>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Channel"/>
                                            <ComboBox Grid.Column="1" x:Name="BrushPaintChannelCombo"/>
                                        </Grid>


                                        <Border x:Name="ScratchContextBannerBorder"
                                                Classes="banner-card"
                                                IsVisible="False">
                                            <TextBlock Text="Scratch mode active"
                                                       Classes="hint"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>

                                        </Border>

                                        <StackPanel x:Name="ColorChannelPanel" Spacing="4">
                                            <TextBlock Text="Color brush" Classes="section-title"/>

                                            <colorpicker:ColorPicker x:Name="BrushPaintColorPicker"
                                                                     IsAlphaEnabled="False"
                                                                     IsAlphaVisible="False"
                                                                     IsHexInputVisible="True"
                                                                     MinHeight="34"/>

                                            <TextBlock Text="Used when channel is color"
                                                       Classes="hint"/>

                                        </StackPanel>

                                        <StackPanel x:Name="PaintChannelTargetValuePanel"
                                                    Spacing="4"
                                                    IsVisible="False">
                                            <TextBlock x:Name="PaintChannelTargetValueLabel"
                                                       Classes="param-label"
                                                       Text="Target value"/>

                                            <controls:ValueInput x:Name="PaintChannelTargetValueInput"
                                                                 Minimum="0"
                                                                 Maximum="1"
                                                                 Value="0.2"
                                                                 Step="0.01"
                                                                 DecimalPlaces="2"/>

                                            <TextBlock x:Name="PaintChannelTargetDisplayText"
                                                       Classes="hint"
                                                       Text="0.20"/>

                                        </StackPanel>

                                        <StackPanel x:Name="GeneralPaintPrimaryPanel" Spacing="6">
                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Brush type"/>
                                                <ComboBox Grid.Column="1" x:Name="BrushTypeCombo"/>
                                            </Grid>


                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Brush size"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="BrushSizeInput" Minimum="1" Maximum="320" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Brush opacity"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="BrushOpacityInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel x:Name="GeneralPaintAdvancedPanel" Spacing="6">
                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Brush darkness"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="BrushDarknessInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Spray spread"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="BrushSpreadInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Coat metallic"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="PaintCoatMetallicInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Coat roughness"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="PaintCoatRoughnessInput" Minimum="0.04" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Clear coat"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="ClearCoatAmountInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="CC roughness"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="ClearCoatRoughnessInput" Minimum="0.04" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Aniso angle"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="AnisotropyAngleInput" Minimum="-180" Maximum="180" Step="0.1" DecimalPlaces="1" Suffix=" deg"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel x:Name="ScratchPrimaryPanel" Spacing="6" IsVisible="False">
                                            <Separator Margin="0,4,0,4"/>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Abrasion type"/>
                                                <ComboBox Grid.Column="1" x:Name="ScratchAbrasionTypeCombo"/>
                                            </Grid>


                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Scratch width"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="ScratchWidthInput" Minimum="1" Maximum="320" Step="0.1" DecimalPlaces="1" Suffix=" px"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Scratch depth"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="ScratchDepthInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel x:Name="ScratchAdvancedPanel" Spacing="6" IsVisible="False">
                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Drag resistance"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="ScratchResistanceInput" Minimum="0" Maximum="0.98" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Depth ramp"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="ScratchDepthRampInput" Minimum="0" Maximum="0.02" Step="0.0001" DecimalPlaces="4"/>
                                            </Grid>

                                            <Separator Margin="0,4,0,4"/>

                                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0"
                                                           Classes="param-label"
                                                           Text="Exposed color"
                                                           VerticalAlignment="Top"
                                                           Margin="0,6,0,0"/>
                                                <StackPanel Grid.Column="1" Spacing="3">
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="R" Classes="channel-r"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="ScratchExposeColorRInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="G" Classes="channel-g"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="ScratchExposeColorGInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="B" Classes="channel-b"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="ScratchExposeColorBInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Exposed metallic"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="ScratchExposeMetallicInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Exposed roughness"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="ScratchExposeRoughnessInput" Minimum="0.04" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                            </Grid>
                                        </StackPanel>

                                        <Button x:Name="ClearPaintMaskButton"
                                                Content="Clear mask"
                                                MinWidth="100"/>

                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="SceneTabItem" Header="Scene">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10" Margin="4">
                                <Expander Header="Tone mapping" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Mode"/>
                                            <ComboBox Grid.Column="1" x:Name="EnvTonemapCombo"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Exposure"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="EnvExposureInput" Minimum="0.1" Maximum="4" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Environment" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Preset"/>
                                            <ComboBox Grid.Column="1" x:Name="EnvPresetCombo"/>
                                        </Grid>
                                        <StackPanel x:Name="EnvironmentManualSettingsPanel" Spacing="6">
                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Intensity"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="EnvIntensityInput" Minimum="0" Maximum="3" Step="0.001" DecimalPlaces="3"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0" Classes="param-label" Text="Roughness response"/>
                                                <controls:ValueInput Grid.Column="1" x:Name="EnvRoughnessMixInput" Minimum="0" Maximum="1" Step="0.001" DecimalPlaces="3"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0"
                                                           Classes="param-label"
                                                           Text="Sky color"
                                                           VerticalAlignment="Top"
                                                           Margin="0,6,0,0"/>
                                                <StackPanel Grid.Column="1" Spacing="3">
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="R" Classes="channel-r"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="EnvTopRInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="G" Classes="channel-g"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="EnvTopGInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="B" Classes="channel-b"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="EnvTopBInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto" ColumnSpacing="8">
                                                <TextBlock Grid.Column="0"
                                                           Classes="param-label"
                                                           Text="Ground color"
                                                           VerticalAlignment="Top"
                                                           Margin="0,6,0,0"/>
                                                <StackPanel Grid.Column="1" Spacing="3">
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="R" Classes="channel-r"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="EnvBottomRInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="G" Classes="channel-g"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="EnvBottomGInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="18,*">
                                                        <TextBlock Grid.Column="0" Text="B" Classes="channel-b"/>
                                                        <controls:ValueInput Grid.Column="1" x:Name="EnvBottomBInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="HDRI · Advanced" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Path"/>
                                            <TextBox Grid.Column="1" x:Name="EnvHdriPathTextBox" Watermark="Path to .hdr/.exr/.png"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button x:Name="EnvHdriApplyButton" Content="Apply HDRI" MinWidth="100"/>
                                            <Button x:Name="EnvHdriClearButton" Content="Clear HDRI" MinWidth="100"/>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="HDRI blend"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="EnvHdriBlendInput" Minimum="0" Maximum="1" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="HDRI rotation"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="EnvHdriRotationInput" Minimum="-360" Maximum="360" Step="0.1" DecimalPlaces="1" Suffix=" deg"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Bloom · Advanced" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Kernel shape"/>
                                            <ComboBox Grid.Column="1" x:Name="EnvBloomKernelShapeCombo"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Bloom strength"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="EnvBloomStrengthInput" Minimum="0" Maximum="4" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Bloom threshold"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="EnvBloomThresholdInput" Minimum="0" Maximum="16" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Bloom knee"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="EnvBloomKneeInput" Minimum="0.001" Maximum="8" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Reflections" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <TextBlock Classes="param-label"
                                                   Text="Coming next: screen-space reflections plus environment probes for shiny glare and bounce."
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="ShadowsTabItem" Header="Shadows">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10" Margin="4">
                                <Expander Header="Enable" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <CheckBox x:Name="ShadowEnabledCheckBox"
                                                  Content="Enable shadows"/>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Source mode"/>
                                            <ComboBox Grid.Column="1" x:Name="ShadowSourceModeCombo"/>
                                        </Grid>

                                    </StackPanel>
                                </Expander>

                                <Expander Header="Projection" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Distance"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ShadowDistanceInput" Minimum="0" Maximum="2.5" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Scale"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ShadowScaleInput" Minimum="0.7" Maximum="1.6" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Softness" IsExpanded="True">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Softness"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ShadowSoftnessInput" Minimum="0" Maximum="1" Step="0.001" DecimalPlaces="3"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Quality"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ShadowQualityInput" Minimum="0" Maximum="1" Step="0.001" DecimalPlaces="3"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Appearance · Advanced" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="0,6,0,0">
                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Strength"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ShadowStrengthInput" Minimum="0" Maximum="2.5" Step="0.001" DecimalPlaces="3"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Shadow gray"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ShadowGrayInput" Minimum="0" Maximum="0.6" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Classes="param-label" Text="Diffuse influence"/>
                                            <controls:ValueInput Grid.Column="1" x:Name="ShadowDiffuseInfluenceInput" Minimum="0" Maximum="2" Step="0.01" DecimalPlaces="2"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="MaterialGraphTabItem" Header="Graph">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="MaterialGraphPanel" Spacing="10" Margin="4">
                                <TextBlock Text="Build procedural materials by connecting nodes"
                                           Classes="hint"/>

                                <CheckBox x:Name="GraphEnabledCheckBox" Content="Enable material graph"/>

                                <TextBlock x:Name="GraphValidationText"
                                           Classes="error-text"
                                           TextWrapping="Wrap"/>

                                <Expander Header="Nodes" IsExpanded="True">
                                    <StackPanel Spacing="6">
                                        <ListBox x:Name="GraphNodeListBox" Height="120"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ComboBox x:Name="AddNodeTypeCombo" Width="160"/>
                                            <Button x:Name="AddNodeButton" Content="Add node" MinWidth="100"/>
                                            <Button x:Name="RemoveNodeButton" Content="Remove" MinWidth="72"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="NodePropertiesExpander" Header="Node properties" IsExpanded="True">
                                    <StackPanel x:Name="NodePropertiesPanel" Spacing="6"/>
                                </Expander>

                                <Expander Header="Connections" IsExpanded="True">
                                    <StackPanel Spacing="6">
                                        <ListBox x:Name="GraphConnectionListBox" Height="120"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button x:Name="AddConnectionButton" Content="Connect..." MinWidth="100"/>
                                            <Button x:Name="RemoveConnectionButton" Content="Disconnect" MinWidth="100"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Preview" IsExpanded="False">
                                    <StackPanel Spacing="6">
                                        <Button x:Name="GraphPreviewBakeButton" Content="Preview bake" MinWidth="140"/>
                                        <Image x:Name="GraphPreviewImage" Width="256" Height="256"/>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    </TabControl>
                </Grid>
            </Border>
            </Grid>

            <!-- Brush dock as Popup — renders in its own native overlay window,
                 which is the only way to composite above NativeControlHost (Metal) on macOS -->
            <Popup x:Name="BrushDockPopup"
                   PlacementTarget="{Binding #ViewportHostBorder}"
                   Placement="AnchorAndGravity"
                   PlacementAnchor="TopLeft"
                   PlacementGravity="BottomRight"
                   HorizontalOffset="12"
                   VerticalOffset="12"
                   IsLightDismissEnabled="False"
                   IsOpen="False"
                   Topmost="True">
                <Border x:Name="ViewportBrushDock"
                        Background="{StaticResource Surface1Brush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="6,4,6,6"
                        Opacity="0.94">
                    <StackPanel Spacing="4">
                        <Border x:Name="BrushDockDragHandle"
                                Height="14"
                                Background="Transparent"
                                HorizontalAlignment="Stretch"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="3">
                                <Ellipse Width="3" Height="3" Fill="{StaticResource TextTertiaryBrush}"/>
                                <Ellipse Width="3" Height="3" Fill="{StaticResource TextTertiaryBrush}"/>
                                <Ellipse Width="3" Height="3" Fill="{StaticResource TextTertiaryBrush}"/>
                                <Ellipse Width="3" Height="3" Fill="{StaticResource TextTertiaryBrush}"/>
                                <Ellipse Width="3" Height="3" Fill="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal" Spacing="0">

                        <!-- Paint toggle -->
                        <StackPanel Spacing="1" VerticalAlignment="Bottom" Margin="2,0,4,0">
                            <TextBlock Text="PAINT"
                                       FontSize="9" FontWeight="SemiBold" LetterSpacing="1"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <Button x:Name="BrushQuickToggleButton"
                                    Width="30" Height="30"
                                    Padding="0"
                                    ToolTip.Tip="Toggle brush painting">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="16" Height="16">
                                        <Path Data="M2,12 L4,14 L9,9 L7,7 Z M7,7 L11,3 L13,5 L9,9 Z"
                                              Fill="{StaticResource TextPrimaryBrush}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>

                        <!-- Divider -->
                        <Border Width="1" Height="30" VerticalAlignment="Bottom"
                                Background="{StaticResource BorderSubtleBrush}" Margin="4,0"/>

                        <!-- Channel group -->
                        <StackPanel Spacing="1" VerticalAlignment="Bottom" Margin="4,0">
                            <TextBlock Text="CHANNEL"
                                       FontSize="9" FontWeight="SemiBold" LetterSpacing="1"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <Button x:Name="BrushQuickColorButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Color channel">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="16" Height="16">
                                            <Path Data="M8,1 C8,1 3,6 3,9 A5,5 0 1 0 13,9 C13,6 8,1 8,1 Z"
                                                  Fill="{StaticResource TextPrimaryBrush}"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button x:Name="BrushQuickScratchButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Scratch channel">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="16" Height="16">
                                            <Path Data="M1,12 L6,7 L9,10 L15,4 L15,6 L9,12 L6,9 L2,13 Z"
                                                  Fill="{StaticResource TextPrimaryBrush}"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button x:Name="BrushQuickEraseButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Erase channel">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="16" Height="16">
                                            <Path Data="M3,9 L8,4 L13,9 L8,14 Z"
                                                  Fill="{StaticResource TextPrimaryBrush}"/>
                                            <Path Data="M5,11 L8,8 L11,11 L8,14 Z"
                                                  Fill="{StaticResource Surface1Brush}"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button x:Name="BrushQuickRustButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Rust channel">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="16" Height="16">
                                            <Ellipse Width="12" Height="12" Canvas.Left="2" Canvas.Top="2"
                                                     Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="1.5"/>
                                            <Ellipse Width="2.5" Height="2.5" Canvas.Left="5" Canvas.Top="5"
                                                     Fill="{StaticResource TextPrimaryBrush}"/>
                                            <Ellipse Width="2" Height="2" Canvas.Left="9" Canvas.Top="8"
                                                     Fill="{StaticResource TextPrimaryBrush}"/>
                                            <Ellipse Width="1.8" Height="1.8" Canvas.Left="6.5" Canvas.Top="9.5"
                                                     Fill="{StaticResource TextPrimaryBrush}"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button x:Name="BrushQuickWearButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Wear channel">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="16" Height="16">
                                            <Path Data="M8,1 A7,7 0 1 1 8,15 A4,4 0 1 0 8,1 Z"
                                                  Fill="{StaticResource TextPrimaryBrush}"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button x:Name="BrushQuickGunkButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Gunk channel">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="16" Height="16">
                                            <Path Data="M3,10 C2,7 4,3 8,3 C11,3 14,5 13,9 C13,12 10,14 7,13 C5,13 3,12 3,10 Z"
                                                  Fill="{StaticResource TextPrimaryBrush}"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Divider -->
                        <Border Width="1" Height="30" VerticalAlignment="Bottom"
                                Background="{StaticResource BorderSubtleBrush}" Margin="4,0"/>

                        <!-- Tool group -->
                        <StackPanel Spacing="1" VerticalAlignment="Bottom" Margin="4,0">
                            <TextBlock Text="TOOL"
                                       FontSize="9" FontWeight="SemiBold" LetterSpacing="1"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <Button x:Name="BrushQuickSprayButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Spray brush">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="18" Height="12">
                                            <Rectangle Width="7" Height="3" Canvas.Left="1" Canvas.Top="7"
                                                       Fill="{StaticResource TextPrimaryBrush}"/>
                                            <Path Data="M8,8 L12,4 L13,5 L9,9 Z"
                                                  Fill="{StaticResource TextPrimaryBrush}"/>
                                            <Ellipse Width="1.4" Height="1.4" Canvas.Left="13" Canvas.Top="1"
                                                     Fill="{StaticResource TextPrimaryBrush}"/>
                                            <Ellipse Width="1.4" Height="1.4" Canvas.Left="15" Canvas.Top="3"
                                                     Fill="{StaticResource TextPrimaryBrush}"/>
                                            <Ellipse Width="1.4" Height="1.4" Canvas.Left="16" Canvas.Top="1.5"
                                                     Fill="{StaticResource TextPrimaryBrush}"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button x:Name="BrushQuickStrokeButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Stroke brush">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="18" Height="12">
                                            <Path Data="M2,10 C5,2 12,2 16,9"
                                                  Stroke="{StaticResource TextPrimaryBrush}"
                                                  StrokeThickness="2" StrokeLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button x:Name="BrushQuickNeedleButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Needle abrasion">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="16" Height="12">
                                            <Rectangle Width="1.4" Height="8" Canvas.Left="7.3" Canvas.Top="1.5"
                                                       Fill="{StaticResource TextPrimaryBrush}"/>
                                            <Path Data="M8,10 L5.8,8.4 L10.2,8.4 Z"
                                                  Fill="{StaticResource TextPrimaryBrush}"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button x:Name="BrushQuickScuffButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Scuff abrasion">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="16" Height="12">
                                            <Path Data="M2,10 L6,6"
                                                  Stroke="{StaticResource TextPrimaryBrush}"
                                                  StrokeThickness="1.6" StrokeLineCap="Round"/>
                                            <Path Data="M6,10 L10,6"
                                                  Stroke="{StaticResource TextPrimaryBrush}"
                                                  StrokeThickness="1.6" StrokeLineCap="Round"/>
                                            <Path Data="M10,10 L14,6"
                                                  Stroke="{StaticResource TextPrimaryBrush}"
                                                  StrokeThickness="1.6" StrokeLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Divider -->
                        <Border Width="1" Height="30" VerticalAlignment="Bottom"
                                Background="{StaticResource BorderSubtleBrush}" Margin="4,0"/>

                        <!-- Actions group -->
                        <StackPanel Spacing="1" VerticalAlignment="Bottom" Margin="4,0,2,0">
                            <TextBlock Text="ACTIONS"
                                       FontSize="9" FontWeight="SemiBold" LetterSpacing="1"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <Button x:Name="BrushQuickAddLayerButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Add paint layer">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="16" Height="12">
                                            <Rectangle Width="8" Height="4" Canvas.Left="2" Canvas.Top="6"
                                                       Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="1.2"/>
                                            <Rectangle Width="8" Height="4" Canvas.Left="4" Canvas.Top="2"
                                                       Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="1.2"/>
                                            <Path Data="M13,1 L13,5 M11,3 L15,3"
                                                  Stroke="{StaticResource TextPrimaryBrush}"
                                                  StrokeThickness="1.2" StrokeLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button x:Name="BrushQuickClearMaskButton"
                                        Width="30" Height="30" Padding="0"
                                        ToolTip.Tip="Clear paint mask">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="16" Height="12">
                                            <Path Data="M2,2 L14,10 M14,2 L2,10"
                                                  Stroke="{StaticResource TextPrimaryBrush}"
                                                  StrokeThickness="1.8" StrokeLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</Window>
